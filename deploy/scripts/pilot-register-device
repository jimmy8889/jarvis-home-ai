#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
from urllib.request import Request, urlopen


def main() -> None:
    parser = argparse.ArgumentParser(description="Register a room device with Pilot Core")
    parser.add_argument("--core-url", required=True)
    parser.add_argument("--device-id", required=True)
    parser.add_argument("--room-id", required=True)
    parser.add_argument("--name", required=True)
    parser.add_argument("--capability", action="append", default=[])
    args = parser.parse_args()
    token = os.environ.get("PILOT_CORE_BOOTSTRAP_TOKEN", "")
    if not token:
        raise SystemExit("PILOT_CORE_BOOTSTRAP_TOKEN is required")
    body = json.dumps(
        {
            "device_id": args.device_id,
            "room_id": args.room_id,
            "name": args.name,
            "capabilities": args.capability,
        }
    ).encode()
    request = Request(
        f"{args.core_url.rstrip('/')}/v1/devices/register",
        data=body,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    with urlopen(request, timeout=10) as response:
        print(json.dumps(json.load(response), indent=2))


if __name__ == "__main__":
    main()
