#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import tempfile
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen


def write_private_token(path: Path, token: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        mode="w", encoding="utf-8", dir=path.parent, delete=False
    ) as handle:
        temporary = Path(handle.name)
        handle.write(token.strip() + "\n")
        handle.flush()
        os.fsync(handle.fileno())
    try:
        os.chmod(temporary, 0o600)
        os.replace(temporary, path)
    finally:
        temporary.unlink(missing_ok=True)


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Redeem a one-time Pilot device bootstrap grant"
    )
    parser.add_argument("--core-url", required=True)
    parser.add_argument("--grant-file", type=Path)
    parser.add_argument("--device-token-file", type=Path, required=True)
    parser.add_argument(
        "--legacy",
        action="store_true",
        help="Use the disabled-by-default reusable bootstrap endpoint",
    )
    parser.add_argument("--device-id")
    parser.add_argument("--room-id")
    parser.add_argument("--name")
    parser.add_argument("--capability", action="append", default=[])
    args = parser.parse_args()

    if args.legacy:
        required = (args.device_id, args.room_id, args.name)
        if not all(required):
            raise SystemExit("legacy registration requires device ID, room ID, and name")
        token = os.environ.get("PILOT_CORE_BOOTSTRAP_TOKEN", "").strip()
        if not token:
            raise SystemExit("PILOT_CORE_BOOTSTRAP_TOKEN is required for legacy mode")
        endpoint = "/v1/devices/register"
        body = json.dumps(
            {
                "device_id": args.device_id,
                "room_id": args.room_id,
                "name": args.name,
                "capabilities": args.capability,
            }
        ).encode()
    else:
        token = os.environ.get("PILOT_DEVICE_BOOTSTRAP_TOKEN", "").strip()
        if args.grant_file:
            try:
                token = json.loads(
                    args.grant_file.read_text(encoding="utf-8")
                )["bootstrap_token"]
            except (OSError, KeyError, TypeError, ValueError) as error:
                raise SystemExit("bootstrap grant file is invalid") from error
        if not token:
            raise SystemExit("--grant-file or PILOT_DEVICE_BOOTSTRAP_TOKEN is required")
        endpoint = "/v1/devices/bootstrap"
        body = b""

    request = Request(
        f"{args.core_url.rstrip('/')}{endpoint}",
        data=body,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with urlopen(request, timeout=10) as response:
            result = json.load(response)
    except HTTPError as error:
        detail = error.read().decode(errors="replace")
        raise SystemExit(f"Pilot Core returned HTTP {error.code}: {detail}") from error
    except (OSError, URLError, ValueError) as error:
        raise SystemExit(f"device bootstrap failed: {error}") from error
    write_private_token(args.device_token_file, result["device_token"])
    print(
        f"Device {result['device_id']} registered; token written to "
        f"{args.device_token_file}."
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
