#!/usr/bin/env python3
from __future__ import annotations

import argparse
from hashlib import sha256
from pathlib import Path
import re
import subprocess
import time
from urllib.error import URLError
from urllib.request import urlopen


def repository_root() -> Path:
    return Path(__file__).resolve().parents[2]


def run(command: list[str], capture: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        command,
        check=True,
        text=True,
        capture_output=capture,
    )


def verify_checksum(archive: Path) -> None:
    checksum = archive.with_suffix(archive.suffix + ".sha256")
    if not checksum.exists():
        raise SystemExit(f"checksum sidecar is required: {checksum}")
    fields = checksum.read_text(encoding="utf-8").split()
    if not fields or not re.fullmatch(r"[a-f0-9]{64}", fields[0]):
        raise SystemExit("backup checksum sidecar is invalid")
    expected = fields[0]
    actual = sha256(archive.read_bytes()).hexdigest()
    if actual != expected:
        raise SystemExit("backup checksum verification failed")


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Restore Pilot Core after taking an automatic safety backup"
    )
    parser.add_argument("--archive", type=Path, required=True)
    parser.add_argument(
        "--compose-file",
        type=Path,
        default=repository_root() / "infra" / "docker-compose.yml",
    )
    parser.add_argument(
        "--safety-backup-directory",
        type=Path,
        default=repository_root() / "infra" / "backups",
    )
    parser.add_argument("--yes", action="store_true")
    parser.add_argument("--core-url", default="http://127.0.0.1:8770")
    args = parser.parse_args()
    if not args.yes:
        raise SystemExit("refusing to restore without --yes")
    archive = args.archive.resolve()
    if not archive.is_file():
        raise SystemExit("backup archive does not exist")
    verify_checksum(archive)
    compose_file = args.compose_file.resolve()
    compose = ["docker", "compose", "-f", str(compose_file)]
    run([*compose, "config", "--quiet"])
    container_id = run(
        [*compose, "ps", "-a", "-q", "pilot-core"], capture=True
    ).stdout.strip()
    if not container_id:
        raise SystemExit("Pilot Core container does not exist; no data volume selected")
    tool_image = run(
        ["docker", "inspect", "--format", "{{.Image}}", container_id],
        capture=True,
    ).stdout.strip()
    volume_name = run(
        [
            "docker",
            "inspect",
            "--format",
            "{{range .Mounts}}{{if eq .Destination \"/data\"}}{{.Name}}{{end}}{{end}}",
            container_id,
        ],
        capture=True,
    ).stdout.strip()
    if not volume_name:
        raise SystemExit("Pilot Core /data named volume could not be resolved")

    backup_tool = repository_root() / "deploy" / "scripts" / "pilot-core-backup"
    run(
        [
            str(backup_tool),
            "--compose-file",
            str(compose_file),
            "--output-directory",
            str(args.safety_backup_directory.resolve()),
            "--label",
            "pre-restore",
            "--tool-image",
            tool_image,
        ]
    )
    running = bool(
        run(
            [*compose, "ps", "--status", "running", "-q", "pilot-core"],
            capture=True,
        ).stdout.strip()
    )
    if running:
        run([*compose, "stop", "pilot-core"])
    try:
        run(
            [
                "docker",
                "run",
                "--rm",
                "--user",
                "0:0",
                "-v",
                f"{volume_name}:/data",
                "-v",
                f"{archive.parent}:/restore:ro",
                "--entrypoint",
                "python",
                tool_image,
                "/opt/pilot-tools/volume_archive.py",
                "restore",
                "--archive",
                f"/restore/{archive.name}",
                "--destination",
                "/data",
            ]
        )
    finally:
        if running:
            run([*compose, "start", "pilot-core"])
    if running:
        ready = False
        for _ in range(30):
            try:
                with urlopen(
                    f"{args.core_url.rstrip('/')}/readyz", timeout=3
                ) as response:
                    ready = response.status == 200
            except (OSError, URLError):
                ready = False
            if ready:
                break
            time.sleep(2)
        if not ready:
            raise SystemExit(
                "Pilot Core did not become ready after restore; use the "
                "pre-restore backup to roll back"
            )
    print(f"Pilot Core data restored from {archive}.")
    print("The pre-restore backup is the rollback path for this operation.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
