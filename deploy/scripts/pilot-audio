#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import sys
import time
from urllib.error import HTTPError, URLError
from urllib.parse import quote, urlencode
from urllib.request import Request, urlopen


CONTENT_TYPES = {
    ".wav": "audio/wav",
    ".flac": "audio/flac",
    ".mp3": "audio/mpeg",
    ".ogg": "audio/ogg",
    ".aac": "audio/aac",
}


def request_json(
    url: str,
    token: str,
    method: str = "GET",
    payload: dict | None = None,
) -> dict:
    body = json.dumps(payload).encode() if payload is not None else None
    request = Request(
        url,
        data=body,
        method=method,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
    )
    with urlopen(request, timeout=15) as response:
        return json.load(response)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Upload verified audio to Pilot Core and play it in a room"
    )
    parser.add_argument("--core-url", required=True)
    parser.add_argument("--room-id", required=True)
    parser.add_argument("--token-env", default="PILOT_CORE_ADMIN_TOKEN")
    parser.add_argument("--kind", choices=("assistant", "announcement"), default="assistant")
    parser.add_argument("--critical", action="store_true")
    parser.add_argument("--volume", type=float, default=1.0)
    parser.add_argument("--retention-seconds", type=int, default=3600)
    parser.add_argument("--expires-in-seconds", type=int, default=30)
    parser.add_argument("--wait", type=float, default=0, metavar="SECONDS")
    parser.add_argument("audio_file", type=Path)
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    token = os.environ.get(args.token_env, "")
    if not token:
        print(f"{args.token_env} is not set", file=sys.stderr)
        return 2
    if args.critical and args.kind != "announcement":
        print("--critical requires --kind announcement", file=sys.stderr)
        return 2
    content_type = CONTENT_TYPES.get(args.audio_file.suffix.lower())
    if content_type is None:
        print("audio_file must be WAV, FLAC, MP3, OGG, or AAC", file=sys.stderr)
        return 2
    try:
        content = args.audio_file.read_bytes()
    except OSError as error:
        print(f"Unable to read audio file: {error}", file=sys.stderr)
        return 2

    base_url = args.core_url.rstrip("/")
    room_id = quote(args.room_id, safe="")
    query = urlencode(
        {
            "kind": args.kind,
            "filename": args.audio_file.name,
            "retention_seconds": args.retention_seconds,
        }
    )
    upload_request = Request(
        f"{base_url}/v1/rooms/{room_id}/audio-assets?{query}",
        data=content,
        method="POST",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": content_type,
        },
    )
    try:
        with urlopen(upload_request, timeout=30) as response:
            asset = json.load(response)
        result = request_json(
            f"{base_url}/v1/rooms/{room_id}/audio",
            token,
            "POST",
            {
                "asset_id": asset["id"],
                "volume": args.volume,
                "critical": args.critical,
                "expires_in_seconds": args.expires_in_seconds,
            },
        )
        command = result["command"]
        deadline = time.monotonic() + max(args.wait, 0)
        while args.wait > 0 and command["status"] in {"queued", "delivered"}:
            if time.monotonic() >= deadline:
                break
            time.sleep(0.5)
            command = request_json(
                f"{base_url}/v1/commands/{command['id']}", token
            )
        result["command"] = command
    except HTTPError as error:
        detail = error.read().decode(errors="replace")
        print(f"Pilot Core returned HTTP {error.code}: {detail}", file=sys.stderr)
        return 1
    except (OSError, URLError, ValueError, KeyError) as error:
        print(f"Pilot audio delivery failed: {error}", file=sys.stderr)
        return 1
    print(json.dumps(result, indent=2, sort_keys=True))
    return 0 if command["status"] not in {"failed", "expired"} else 1


if __name__ == "__main__":
    raise SystemExit(main())
