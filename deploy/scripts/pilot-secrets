#!/usr/bin/env python3
from __future__ import annotations

import argparse
import os
from pathlib import Path
import secrets
import stat
import sys
import tempfile


SECRET_NAMES = {
    "pilot_core_admin_token": True,
    "pilot_core_bootstrap_token": True,
    "music_assistant_token": False,
    "home_assistant_token": False,
    "tts_token": False,
}
DEFAULT_CONTAINER_GID = 10_001


def default_directory() -> Path:
    return Path(__file__).resolve().parents[2] / "infra" / "secrets"


def secret_mode(runtime_gid: int | None) -> int:
    return 0o640 if runtime_gid is not None else 0o600


def apply_secret_permissions(path: Path, runtime_gid: int | None) -> None:
    os.chmod(path, secret_mode(runtime_gid))
    if runtime_gid is not None:
        os.chown(path, -1, runtime_gid)


def write_secret(
    path: Path,
    value: str,
    replace: bool,
    runtime_gid: int | None,
) -> None:
    path.parent.mkdir(parents=True, exist_ok=True, mode=0o700)
    os.chmod(path.parent, 0o700)
    if path.exists() or path.is_symlink():
        if path.is_symlink() or not path.is_file():
            raise SystemExit(f"refusing unsafe secret path: {path}")
    if path.exists() and not replace:
        apply_secret_permissions(path, runtime_gid)
        return
    with tempfile.NamedTemporaryFile(
        mode="w",
        encoding="utf-8",
        dir=path.parent,
        prefix=f".{path.name}.",
        delete=False,
    ) as handle:
        temporary = Path(handle.name)
        handle.write(value.strip() + ("\n" if value.strip() else ""))
        handle.flush()
        os.fsync(handle.fileno())
    try:
        apply_secret_permissions(temporary, runtime_gid)
        os.replace(temporary, path)
    finally:
        temporary.unlink(missing_ok=True)


def check_directory(directory: Path, runtime_gid: int | None) -> int:
    failures = 0
    expected_mode = secret_mode(runtime_gid)
    if not directory.is_dir():
        print(f"FAIL  secret directory does not exist: {directory}")
        return 1
    if stat.S_IMODE(directory.stat().st_mode) != 0o700:
        print("FAIL  secret directory mode must be 0700")
        failures += 1
    for name, required in SECRET_NAMES.items():
        path = directory / name
        if not path.is_file() or path.is_symlink():
            print(f"FAIL  {name} is missing or not a regular file")
            failures += 1
            continue
        details = path.stat()
        if stat.S_IMODE(details.st_mode) != expected_mode:
            print(f"FAIL  {name} mode must be {expected_mode:04o}")
            failures += 1
        if runtime_gid is not None and details.st_gid != runtime_gid:
            print(f"FAIL  {name} group must be GID {runtime_gid}")
            failures += 1
        try:
            value = path.read_text(encoding="utf-8").strip()
        except (OSError, UnicodeError):
            print(f"FAIL  {name} cannot be read")
            failures += 1
            continue
        if required and len(value) < 32:
            print(f"FAIL  {name} must contain at least 32 characters")
            failures += 1
        else:
            state = "configured" if value else "empty (optional)"
            print(f"PASS  {name}: {state}")
    return failures


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Create and validate file-backed Pilot Core secrets"
    )
    parser.add_argument("--directory", type=Path, default=default_directory())
    parser.add_argument(
        "--runtime-gid",
        type=int,
        help=(
            "grant read access to the container group; defaults to "
            f"{DEFAULT_CONTAINER_GID} when run as root"
        ),
    )
    subparsers = parser.add_subparsers(dest="action", required=True)
    subparsers.add_parser("init")
    subparsers.add_parser("check")
    rotate = subparsers.add_parser("rotate")
    rotate.add_argument(
        "name",
        choices=("pilot_core_admin_token", "pilot_core_bootstrap_token"),
    )
    set_parser = subparsers.add_parser("set")
    set_parser.add_argument("name", choices=tuple(SECRET_NAMES))
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    directory: Path = args.directory.expanduser().resolve()
    runtime_gid = args.runtime_gid
    if runtime_gid is None and os.geteuid() == 0:
        runtime_gid = DEFAULT_CONTAINER_GID
    if runtime_gid is not None and runtime_gid < 0:
        raise SystemExit("--runtime-gid must not be negative")
    if args.action == "init":
        for name, required in SECRET_NAMES.items():
            value = secrets.token_urlsafe(48) if required else ""
            write_secret(
                directory / name,
                value,
                replace=False,
                runtime_gid=runtime_gid,
            )
        print(f"Pilot secret files initialized in {directory}.")
        return check_directory(directory, runtime_gid)
    if args.action == "check":
        return 1 if check_directory(directory, runtime_gid) else 0
    if args.action == "rotate":
        write_secret(
            directory / args.name,
            secrets.token_urlsafe(48),
            replace=True,
            runtime_gid=runtime_gid,
        )
        print(f"Rotated {args.name}; dependent services must be restarted.")
        return 0
    value = sys.stdin.read().strip()
    if not value:
        raise SystemExit("refusing to store an empty secret")
    write_secret(
        directory / args.name,
        value,
        replace=True,
        runtime_gid=runtime_gid,
    )
    print(f"Stored {args.name} from standard input.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
